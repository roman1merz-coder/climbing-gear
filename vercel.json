  "rewrites": [
    {
      "source": "/ingest/static/(.*)",
      "destination": "https://eu-assets.i.posthog.com/static/$1"
    },
    {
      "source": "/ingest/(.*)",
      "destination": "https://eu.i.posthog.com/$1"
    },
    {
      "source": "/compare",
      "destination": "/index.html"
    },
    {
      "source": "/compare-ropes",
      "destination": "/index.html"
    },
    {
      "source": "/compare-belays",
      "destination": "/index.html"
    },
    {
      "source": "/compare-pads",
      "destination": "/index.html"
    },
