      "source": "/compare-quickdraws",
      "destination": "/index.html"
    },
    {
      "source": "/wishlist",
      "destination": "/index.html"
    },
    {
      "source": "/scan",
      "destination": "/scan.html"
    },
    {
      "source": "/scan-testv2",
      "destination": "/scan-testv2.html"
    },
    {
      "source": "/scan/petz/:scanId",
      "destination": "/scan/petz/:scanId.html"
    },
    {
      "source": "/scan/:scanId/browse",
      "destination": "/scan-browse.html"
    },
    {
      "source": "/scan/:scanId",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/fetch-prices.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/fetch-prices?limit=50",
      "schedule": "0 4 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(), payment=()"
        }
      ]
    },
    {
      "source": "/scan",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(self), payment=()"
        }
      ]
    },
    {
      "source": "/scan.html",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(self), payment=()"
        }
      ]
    },
    {
      "source": "/scan-testv2",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(self), payment=()"
        }
      ]
    },
    {
      "source": "/scan-testv2.html",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(self), payment=()"
        }
      ]
    }
  ]
}
